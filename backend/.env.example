# Copy to .env and adjust. Never commit .env -- it is gitignored.

ENV=development

# SQLite needs no setup. For Postgres via docker-compose:
# DATABASE_URL=postgresql://aura:aura@localhost:5432/aura
DATABASE_URL=sqlite:///./aura_dev.db

# Download the service account JSON from the Firebase console
# (Project settings -> Service accounts -> Generate new private key).
# Leave empty until a Firebase project exists; dev auth covers local work.
FIREBASE_CREDENTIALS_PATH=

# Allows `Authorization: Bearer dev <email>` for local testing.
# Ignored unless ENV=development.
ALLOW_DEV_AUTH=true

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Get one at https://aistudio.google.com/apikey -- free, and separate from any
# Gemini app subscription. Leave empty to use the mock parser instead.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Used automatically when the primary model hits its quota. Free-tier limits
# are per-model, so the lighter model usually still has budget.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
